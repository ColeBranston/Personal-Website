# URL to the raw config.json hosted in your personal-website-config GitHub repo.
CONFIG_URL=https://raw.githubusercontent.com/ColeBranston/personal-website-config/main/config.json

# Redis (Redis Cloud) connection used to cache config.json and GitHub commit/graph
# data so the site doesn't hit GitHub's or GitHub's raw-content rate limits on
# every visitor. Format: redis://default:<password>@<host>:<port>
REDIS_URL=

# Optional but recommended: a GitHub Personal Access Token (no scopes needed for
# public repos) raises the GitHub REST API rate limit from 60/hr to 5,000/hr.
# Create one at https://github.com/settings/tokens
TOKEN=

# How long (in seconds) cached GitHub commit data stays fresh before being
# re-fetched from the GitHub API. Defaults to 3600 (1 hour) if unset.
COMMITS_CACHE_TTL=3600

# How long (in seconds) the fetched config.json stays cached. Defaults to 300
# (5 minutes) if unset, so edits to config.json show up quickly.
CONFIG_CACHE_TTL=300

DEPLOYMENT_ENV=local